// 综合词法分析测试用例

// 1. 关键字测试
int main() {
    void return const float if else;
    
    // 2. 标识符测试
    int variableName;
    float _privateVar;
    const int MAX_SIZE = 100;
    float piValue = 3.14159;
    int k123fe_ = 1;
    
    // 3. 整数字面量测试
    int decimal = 12345;
    int zero = 0;
    int largeNum = 2147483647;  // 最大int值
    
    // 4. 浮点数字面量测试
    float simpleFloat = 3.14;
    float zeroPoint = 0.0;
    
    // 5. 运算符测试
    int a = 10;
    int b = 20;
    
    // 算术运算符
    int sum = a + b;
    int diff = a - b;
    int prod = a * b;
    int quot = a / b;
    int rem = a % b;
    
    // 比较运算符
    int eq = a == b;
    int ne = a != b;
    int lt = a < b;
    int gt = a > b;
    int le = a <= b;
    int ge = a >= b;
    
    // 逻辑运算符
    int andResult = (a > 0) && (b > 0);
    int orResult = (a > 0) || (b > 0);
    int notResult = !a;
    
    // 赋值运算符
    a = b;
    a += 1;
    a -= 2;
    a *= 3;
    a /= 4;
    a %= 5;
    
    // 6. 界符测试
    if (a > 0) {
        return a;
    } else {
        return b;
    }
    
    // 7. 注释测试
    // 这是单行注释
    
    /*
     * 这是多行注释
     * 包含多行内容
     * 可以测试注释的正确处理
     */
    
    // 8. 特殊情况测试
    int negative = -42;
    float negativeFloat = -3.14;
    
    return 0;
}

// 函数定义测试
int add(int x, int y) {
    return x + y;
}

float divide(float a, float b) {
    if (b != 0.0) {
        return a / b;
    }
    return 0.0;
}

// 全局变量测试
const int GLOBAL_CONST = 1000;
float globalFloat = 2.718;
