# 指定g++完整路径（Windows环境）
CXX = G:/444SoftWare/MSYS-251020/ucrt64/bin/g++.exe
CXXFLAGS = -std=c++11 -Wall -Iinclude -Iir_lib/include
LDFLAGS = -Lir_lib -lir

SRC_DIR = src
INCLUDE_DIR = include
BUILD_DIR = build
PROCESS_DIR = process
IR_LIB_DIR = ir_lib

LEXER_SRC = $(SRC_DIR)/lexer.cpp
LEXER_OBJ = $(BUILD_DIR)/lexer.o
LEXER_EXE = $(BUILD_DIR)/lexer

PARSER_SRC = $(SRC_DIR)/parser.cpp
PARSER_OBJ = $(BUILD_DIR)/parser.o
PARSER_EXE = $(BUILD_DIR)/parser

PARSER_WRAPPER_SRC = $(SRC_DIR)/parser_wrapper.cpp
PARSER_WRAPPER_OBJ = $(BUILD_DIR)/parser_wrapper.o

# 中间代码生成相关文件
AST_SRC = $(SRC_DIR)/ast.cpp
AST_OBJ = $(BUILD_DIR)/ast.o

SYMBOL_TABLE_SRC = $(SRC_DIR)/symbol_table.cpp
SYMBOL_TABLE_OBJ = $(BUILD_DIR)/symbol_table.o

IR_GENERATOR_SRC = $(SRC_DIR)/ir_generator.cpp
IR_GENERATOR_OBJ = $(BUILD_DIR)/ir_generator.o

MAIN_SRC = $(SRC_DIR)/main.cpp
MAIN_OBJ = $(BUILD_DIR)/main.o

# 测试相关文件（放在src目录下）
TEST_AST_BUILDER_SRC = $(SRC_DIR)/test_ast_builder.cpp
TEST_AST_BUILDER_OBJ = $(BUILD_DIR)/test_ast_builder.o

TEST_IR_GENERATOR_SRC = $(SRC_DIR)/test_ir_generator.cpp
TEST_IR_GENERATOR_OBJ = $(BUILD_DIR)/test_ir_generator.o
TEST_IR_GENERATOR_EXE = $(BUILD_DIR)/test_ir_generator

COMPILER_EXE = $(BUILD_DIR)/compiler
COMPILER_OBJS = $(LEXER_OBJ) $(PARSER_OBJ) $(PARSER_WRAPPER_OBJ) $(AST_OBJ) $(SYMBOL_TABLE_OBJ) $(IR_GENERATOR_OBJ) $(MAIN_OBJ)

# IR库文件
IR_LIB_SRCS = $(wildcard $(IR_LIB_DIR)/src/*.cpp)
IR_LIB_OBJS = $(patsubst $(IR_LIB_DIR)/src/%.cpp,$(BUILD_DIR)/ir_lib/%.o,$(IR_LIB_SRCS))
IR_LIB = $(BUILD_DIR)/libir.a

.PHONY: all
all: compiler

$(BUILD_DIR):
	@if not exist "$(BUILD_DIR)" mkdir "$(BUILD_DIR)"
	@if not exist "$(BUILD_DIR)\ir_lib" mkdir "$(BUILD_DIR)\ir_lib"

$(PROCESS_DIR):
	@if not exist "$(PROCESS_DIR)" mkdir "$(PROCESS_DIR)"

# 构建IR库
$(IR_LIB): $(IR_LIB_OBJS)
	ar rcs $@ $^

$(BUILD_DIR)/ir_lib/%.o: $(IR_LIB_DIR)/src/%.cpp
	$(CXX) $(CXXFLAGS) -c -o $@ $<

# 编译词法分析器
lexer: $(BUILD_DIR) $(PROCESS_DIR) $(LEXER_EXE)

$(LEXER_EXE): $(LEXER_SRC) $(INCLUDE_DIR)/lexer.h
	$(CXX) $(CXXFLAGS) -o $@ $(LEXER_SRC)
	@echo Lexer compiled successfully!

# 编译语法分析器
parser: $(BUILD_DIR) $(PROCESS_DIR) $(PARSER_EXE)

$(PARSER_EXE): $(PARSER_SRC) $(INCLUDE_DIR)/parser.h $(INCLUDE_DIR)/lexer.h
	$(CXX) $(CXXFLAGS) -DNO_MAIN -o $@ $(PARSER_SRC) $(SRC_DIR)/lexer.cpp
	@echo Parser compiled successfully!

# 编译各个目标文件
$(LEXER_OBJ): $(LEXER_SRC) $(INCLUDE_DIR)/lexer.h
	$(CXX) $(CXXFLAGS) -c -o $@ $(LEXER_SRC)

$(PARSER_OBJ): $(PARSER_SRC) $(INCLUDE_DIR)/parse.h $(INCLUDE_DIR)/lexer.h
	$(CXX) $(CXXFLAGS) -c -o $@ $(PARSER_SRC)

$(PARSER_WRAPPER_OBJ): $(PARSER_WRAPPER_SRC) $(INCLUDE_DIR)/parser.h $(INCLUDE_DIR)/parse.h
	$(CXX) $(CXXFLAGS) -c -o $@ $(PARSER_WRAPPER_SRC)

$(AST_OBJ): $(AST_SRC) $(INCLUDE_DIR)/ast.h
	$(CXX) $(CXXFLAGS) -c -o $@ $(AST_SRC)

$(SYMBOL_TABLE_OBJ): $(SYMBOL_TABLE_SRC) $(INCLUDE_DIR)/symbol_table.h
	$(CXX) $(CXXFLAGS) -c -o $@ $(SYMBOL_TABLE_SRC)

$(IR_GENERATOR_OBJ): $(IR_GENERATOR_SRC) $(INCLUDE_DIR)/ir_generator.h $(INCLUDE_DIR)/ast.h $(INCLUDE_DIR)/symbol_table.h
	$(CXX) $(CXXFLAGS) -c -o $@ $(IR_GENERATOR_SRC)

$(MAIN_OBJ): $(MAIN_SRC) $(INCLUDE_DIR)/lexer.h $(INCLUDE_DIR)/parse.h $(INCLUDE_DIR)/ast.h $(INCLUDE_DIR)/ir_generator.h
	$(CXX) $(CXXFLAGS) -c -o $@ $(MAIN_SRC)

# 编译测试相关目标文件
$(TEST_AST_BUILDER_OBJ): $(TEST_AST_BUILDER_SRC) $(INCLUDE_DIR)/ast.h
	$(CXX) $(CXXFLAGS) -c -o $@ $(TEST_AST_BUILDER_SRC)

$(TEST_IR_GENERATOR_OBJ): $(TEST_IR_GENERATOR_SRC) $(INCLUDE_DIR)/ir_generator.h
	$(CXX) $(CXXFLAGS) -c -o $@ $(TEST_IR_GENERATOR_SRC)

# 编译完整编译器（包含中间代码生成）
compiler: $(BUILD_DIR) $(PROCESS_DIR) $(IR_LIB) $(COMPILER_EXE)

$(COMPILER_EXE): $(COMPILER_OBJS) $(IR_LIB)
	$(CXX) $(CXXFLAGS) -o $@ $(COMPILER_OBJS) $(IR_LIB)
	@echo Compiler with IR generation compiled successfully!

# 编译IR生成器测试程序
test-ir: $(BUILD_DIR) $(TEST_IR_GENERATOR_EXE)

$(TEST_IR_GENERATOR_EXE): $(TEST_IR_GENERATOR_OBJ) $(TEST_AST_BUILDER_OBJ) $(IR_GENERATOR_OBJ) $(AST_OBJ) $(SYMBOL_TABLE_OBJ) $(IR_LIB_OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $(TEST_IR_GENERATOR_OBJ) $(TEST_AST_BUILDER_OBJ) $(IR_GENERATOR_OBJ) $(AST_OBJ) $(SYMBOL_TABLE_OBJ) $(IR_LIB_OBJS)
	@if not exist "output" mkdir "output"
	@echo IR生成器测试程序编译完成！

# 运行IR生成器测试
.PHONY: run-test-ir
run-test-ir: test-ir
	$(TEST_IR_GENERATOR_EXE)

# 快速编译（不重新构建IR库）
quick: $(BUILD_DIR) $(COMPILER_OBJS)
	$(CXX) $(CXXFLAGS) -o $(COMPILER_EXE) $(COMPILER_OBJS) $(IR_LIB)
	@echo Quick build completed!

.PHONY: clean
clean:
	@if exist "$(BUILD_DIR)" rmdir /s /q "$(BUILD_DIR)"
	@if exist "output" rmdir /s /q "output"
	@echo Cleaned build directory and output.

.PHONY: clean-all
clean-all:
	@if exist "$(BUILD_DIR)" rmdir /s /q "$(BUILD_DIR)"
	@if exist "$(PROCESS_DIR)" rmdir /s /q "$(PROCESS_DIR)"
	@if exist "output" rmdir /s /q "output"
	@echo Cleaned build, process and output directories.

# 运行目标
.PHONY: run-lexer
run-lexer: lexer
	$(LEXER_EXE)

.PHONY: run-parser
run-parser: parser
	$(PARSER_EXE)

.PHONY: run
run: compiler
	$(COMPILER_EXE)

# 测试目标
.PHONY: test-lexer
test-lexer: lexer
	$(LEXER_EXE) case/test.sy

.PHONY: test-parser
test-parser: parser
	$(PARSER_EXE) case/test.sy

.PHONY: test
test: compiler
	$(COMPILER_EXE) case/test.sy

.PHONY: test-ir-output
test-ir-output: compiler
	@if not exist "output" mkdir "output"
	$(COMPILER_EXE) case/test.sy > output/test_output.ll
	@echo IR generated to output/test_output.ll

.PHONY: debug
debug: CXXFLAGS += -g -DDEBUG
debug: compiler

# 只构建IR生成器（用于测试）
.PHONY: ir-test
ir-test: $(BUILD_DIR) $(IR_GENERATOR_OBJ) $(AST_OBJ) $(SYMBOL_TABLE_OBJ)
	@echo IR generator objects compiled successfully!

# 依赖关系
$(COMPILER_OBJS): | $(BUILD_DIR)

# 显示文件信息
.PHONY: info
info:
	@echo "Source files:"
	@echo "  Lexer: $(LEXER_SRC)"
	@echo "  Parser: $(PARSER_SRC)"
	@echo "  Parser Wrapper: $(PARSER_WRAPPER_SRC)"
	@echo "  AST: $(AST_SRC)"
	@echo "  Symbol Table: $(SYMBOL_TABLE_SRC)"
	@echo "  IR Generator: $(IR_GENERATOR_SRC)"
	@echo "  Main: $(MAIN_SRC)"
	@echo "Test files:"
	@echo "  Test AST Builder: $(TEST_AST_BUILDER_SRC)"
	@echo "  Test IR Generator: $(TEST_IR_GENERATOR_SRC)"
	@echo "IR Library files:"
	@echo "  $(IR_LIB_SRCS)"

.PHONY: help
help:
	@echo Available targets:
	@echo "  all (default)     - Build the complete compiler with IR generation"
	@echo "  compiler          - Build the complete compiler (lexer + parser + IR)"
	@echo "  lexer             - Build only the lexer"
	@echo "  parser            - Build only the parser"
	@echo "  test-ir           - Build IR generator test program"
	@echo "  run-test-ir       - Run IR generator tests"
	@echo "  ir-test           - Build only IR generator components"
	@echo "  quick             - Quick build (skip IR library rebuild)"
	@echo "  clean             - Remove build files and output"
	@echo "  clean-all         - Remove build, process and output directories"
	@echo "  run               - Run compiler with standard input"
	@echo "  run-lexer         - Run lexer with standard input"
	@echo "  run-parser        - Run parser with standard input"
	@echo "  test              - Run compiler with case/test.sy"
	@echo "  test-lexer        - Run lexer with case/test.sy"
	@echo "  test-parser       - Run parser with case/test.sy"
	@echo "  test-ir-output    - Run compiler and output IR to output/test_output.ll"
	@echo "  debug             - Build with debug information"
	@echo "  info              - Show source file information"
	@echo "  help              - Show this help message"