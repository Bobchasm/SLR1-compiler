// 测试逻辑运算符（符合SysY语言规范）
int main() {
    int a = 1;
    int b = 0;
    int c = 2;
    int result;
    
    // 在if语句的条件中使用逻辑运算符（这是允许的）
    if (a && b) {
        result = 1;
    }
    
    if (a || b) {
        result = 2;
    }
    
    // 复杂的逻辑表达式在条件中
    if ((a && b) || (a + b >= 0)) {
        result = 3;
    }
    
    if ((a > 0 && b < 0) || (c != 0)) {
        result = 4;
    }
    
    // 更复杂的嵌套逻辑表达式
    if ((a > 0 && b >= 0) || (c <= 2 && a != b)) {
        result = 5;
    }
    
    // 混合算术和逻辑运算在条件中
    if ((a + b > 0) && (c * 2 < 10) || (result == 0)) {
        result = 6;
    }
    
    // 多层嵌套的逻辑表达式
    int x = 5;
    int y = 10;
    int z = 15;
    
    if (((x > 0 && y > 0) || (z > 20)) && ((x < 10 || y < 5) && z != 0)) {
        result = 7;
    }
    
    // 包含算术运算和比较运算的复杂逻辑表达式
    if ((x + y > z) && (x * 2 < y + z) || (z % 3 == 0)) {
        result = 8;
    }
    
    return result;
}