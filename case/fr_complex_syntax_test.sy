// 复杂语法分析测试用例
// 包含各种文法规则和复杂嵌套结构

// 全局常量声明
const int GLOBAL_MAX = 1000;
const float PI = 3.14159;
const int ARRAY_SIZE = 10;

// 全局变量声明
int global_counter = 0;
float global_rate = 0.05;

// 主函数
int main() {
    // 局部变量声明
    int x = 10;
    int y = 20;
    float z = 3.14;
    const int LOCAL_CONST = 42;
    
    // 复杂算术表达式
    int result1 = x + y * 2 - 5 / 2 % 3;
    float result2 = (z + 1.5) * 2.0 / 3.14;
    
    // 嵌套if-else语句
    if (x > 0) {
        if (y > 0) {
            if (z > 0.0) {
                global_counter = global_counter + 1;
            } else {
                global_counter = global_counter - 1;
            }
        } else {
            global_counter = global_counter + 2;
        }
    } else {
        global_counter = 0;
    }
    
    // 复杂的if-else if-else结构
    
    if (result1 == 0) {
        result1 = 1;
    } else if (result1 == 1) {
        result1 = 2;
    } else if (result1 == 2) {
        result1 = 3;
    } else {
        result1 = 0;
    }
    
    // 逻辑表达式测试
    if (((x > 0 && y > 0) || (z > 20)) && ((x < 10 || y < 5) && z != 0)) {
        int temp = factorial(5);
        float pow_result = power(2.0, 3);
    }
    
    // 复杂的函数调用
    int fact_result = factorial(x);
    float power_result = power(z, 2);
    
    // 多层嵌套表达式
    int complex_expr = ((((x + 1) * 2) - 3) / 4) % 5;
    
    // 比较运算符组合
    if (x >= 0 && y <= 100) {
        global_rate = global_rate + 0.01;
    }
    
    // 逻辑运算符组合
    if (x > 0 || y < 0) {
        global_counter = global_counter + 1;
    }
    
    // 返回语句
    return fact_result + power_result;
}

// 递归阶乘函数
int factorial(int n) {
    if (n <= 1) {
        return 1;
    } else {
        return n * factorial(n - 1);
    }
}

// 幂函数
float power(float base, int exp) {
    if (exp == 0) {
        return 1.0;
    } else if (exp > 0) {
        float result = 1.0;
        int i = 0;
        return result;
    } else {
        return 1.0 / power(base, -exp);
    }
}

// 交换函数（注意：这里只是演示语法，实际不会交换）
void swap(int a, int b) {
    int temp = a;
    a = b;
    b = temp;
    return;
}

// 带有多个参数的复杂函数
int complex_calculation(int a, int b, float c, int d) {
    const float multiplier = 2.5;
    int result = 0;
    
    // 复杂的控制流
    if (a > 0) {
        if (b > 0) {
            if (c > 0.0) {
                result = (a + b) * c * d;
            } else {
                result = (a - b) / d;
            }
        } else {
            result = a * b * d;
        }
    } else {
        result = 0;
    }
    
    // 嵌套的条件表达式
    
    return result;
}

// 测试函数调用和表达式
void test_expressions() {
    int a = 10;
    int b = 20;
    float c = 3.14;
    
    // 复杂的函数调用表达式
    int result1 = complex_calculation(a, b, c, 5);
    int result2 = factorial(complex_calculation(1, 2, 1.5, 3));
    
    // 嵌套的函数调用
    // float result3 = power(power(2.0, 2), 2);
    
    // 复杂的逻辑表达式
    if (a + b > 25) {
        global_counter = global_counter + result1;
    }
    
    return;
}
