// 调试逻辑表达式问题
int main() {
    int a = 1;
    int b = 0;
    int c = 2;
    
    // 简单的逻辑表达式 - 应该可以工作
    if (a && b) {
        return 1;
    }
    
    // 复杂的逻辑表达式 - 可能有问题
    if ((a && b) || (a + b >= 0)) {
        return 2;
    }
    
    // 另一个复杂的逻辑表达式
    if ((a > 0 && b < 0) || (c != 0)) {
        return 3;
    }
    
    return 0;
}