// 边界测试3: 零值和边界值
int main() {
    int zero = 0;
    int negative = 0;
    int positive = 0;
    
    // 测试零值运算
    int result1 = 0 + 0;
    int result2 = 10 * 0;
    int result3 = 0 / 10;  // 注意：除以零应该避免
    
    // 测试边界比较
    if (zero == 0) {
        result1 = 1;
    }
    
    if (zero != 0) {
        result2 = 1;
    }
    
    return 0;
}
