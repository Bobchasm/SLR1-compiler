// 测试if条件中的复杂逻辑表达式
int main() {
    int a = 1;
    int b = 0;
    int c = 2;
    
    // 这个应该可以工作
    if (a && b) {
        return 1;
    }
    
    // 这个可能有问题 - 复杂的逻辑表达式
    if ((a && b) || (a + b >= 0)) {
        return 2;
    }
    
    // 这个也可能有问题
    if ((a > 0 && b < 0) || (c != 0)) {
        return 3;
    }
    
    return 0;
}