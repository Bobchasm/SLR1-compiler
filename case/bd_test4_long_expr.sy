// 边界测试4: 长表达式
int main() {
    int a = 1;
    int b = 2;
    int c = 3;
    int d = 4;
    int e = 5;
    
    // 长算术表达式
    int result = a + b * c + d * e + a * b + c * d + e * a;
    
    // 长比较表达式
    if (a < b) {
        if (b < c) {
            if (c < d) {
                if (d < e) {
                    result = 100;
                }
            }
        }
    }
    
    return result;
}
