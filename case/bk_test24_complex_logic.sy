// 测试复杂的逻辑表达式
int main() {
    int a = 1;
    int b = 0;
    int c = 2;
    
    int result1;
    
    // 更复杂的嵌套逻辑表达式
    if ((a > 0 && b >= 0) || (c <= 2 && a != b)) {
        result1 = 10;
    }
    
    
    // 使用逻辑表达式作为条件
    if ((a && b) || (c > 0)) {
        return 1;
    } else {
        return 0;
    }
    
    // 测试更复杂的逻辑表达式
    int x = 5;
    int y = 10;
    int z = 15;
    
    // 多层嵌套的逻辑表达式
    if (((x > 0 && y > 0) || (z > 20)) && ((x < 10 || y < 5) && z != 0)) {
        int temp = 1;
    }
    
    
    return 0;
}