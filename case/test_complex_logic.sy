// 测试复杂的逻辑表达式
int main() {
    int a = 1;
    int b = 0;
    int c = 2;
    
    // 简单逻辑运算
    int result1 = a && b;  // 1 && 0 = 0
    int result2 = a || b;  // 1 || 0 = 1
    
    // 复杂逻辑表达式 - 这个之前有问题
    int result3 = (a && b) || (a + b >= 0);  // (1 && 0) || (1 + 0 >= 0) = 0 || 1 = 1
    int result4 = (a > 0 && b < 0) || (c != 0);  // (1 > 0 && 0 < 0) || (2 != 0) = (1 && 0) || 1 = 1
    
    // 更复杂的嵌套逻辑表达式
    if ((a > 0 && b >= 0) || (c <= 2 && a != b)) {
        result1 = 10;
    }
    
    // 混合算术和逻辑运算
    int complex_condition = (a + b > 0) && (c * 2 < 10) || (result1 == 0);
    
    // 使用逻辑表达式作为条件
    if ((a && b) || (c > 0)) {
        return 1;
    } else {
        return 0;
    }
    
    // 测试更复杂的逻辑表达式
    int x = 5;
    int y = 10;
    int z = 15;
    
    // 多层嵌套的逻辑表达式
    if (((x > 0 && y > 0) || (z > 20)) && ((x < 10 || y < 5) && z != 0)) {
        int temp = 1;
    }
    
    // 包含算术运算和比较运算的复杂逻辑表达式
    int final_result = (x + y > z) && (x * 2 < y + z) || (z % 3 == 0);
    
    return final_result;
}