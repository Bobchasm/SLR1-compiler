// 中端测试4: 复杂表达式
// 测试嵌套表达式和多次赋值

int main() {
    int a = 5;
    int b = 10;
    int c = 15;
    int d;
    
    d = a + b * c;
    d = (a + b) * c;
    d = a * b + c;
    d = a / b + c * d;
    
    if (d > 100) {
        d = 100;
    } else if (d > 50) {
        d = 50;
    } else {
        d = 0;
    }
    
    return d;
}
