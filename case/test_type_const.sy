// 测试常量的类型转换
int main() {
    // const float 接受 int（无警告）
    const float PI = 3;
    const float E = 2;
    
    // const int 接受 float（警告：截断）
    const int MAX = 100.9;      // 警告：截断为 100
    const int MIN = 0.1;        // 警告：截断为 0
    
    // 使用常量
    float area = PI * 10.0 * 10.0;
    int count = MAX - MIN;
    
    return count;
}

void test_const_params(const int x, const float y) {
    return;
}

int test_calls() {
    const float cf = 5.5;
    const int ci = 10;
    
    test_const_params(cf, ci);   // 第一个参数警告截断，第二个无警告
    
    return 0;
}
