// 前端测试3: 控制流测试
// 测试if-else语句和比较运算

int main() {
    int a = 10;
    int b = 20;
    
    if (a < b) {
        a = b;
    } else {
        b = a;
    }
    
    if (a == b) {
        return 1;
    }
    
    if (a != b) {
        return 2;
    }
    
    if (a >= b) {
        return 3;
    }
    
    if (a <= b) {
        return 4;
    }
    
    return 0;
}
